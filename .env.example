# ============================================================
# Nursing Home Acquisition Alert System — Environment Config
# Copy to .env and fill in your values
# ============================================================

# Postgres connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/nursing_home_alerts

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid (for email digests)
SENDGRID_API_KEY=SG....
ALERT_FROM_EMAIL=alerts@yourorg.org
ALERT_TO_EMAILS=researcher1@yourorg.org,researcher2@yourorg.org

# S3 or GCS bucket for raw article archive (optional)
# Leave blank to skip archiving
ARCHIVE_BUCKET=your-bucket-name

# Google News API key (optional — for Google News sweep source)
# Get from https://serpapi.com or https://newsdataapi.io
GOOGLE_NEWS_API_KEY=

# SEC EDGAR contact email (required by EDGAR fair-use policy)
# SEC will block requests without a real contact email in the User-Agent
EDGAR_CONTACT_EMAIL=research@yourorg.org

# Dashboard CORS — comma-separated allowed origins
# Set to your internal domain(s) in production
ALLOWED_ORIGINS=https://dashboard.yourorg.org
# FUZZY_MATCH_THRESHOLD=70
# RECHECK_INTERVAL_DAYS=7
# MAX_ARTICLE_AGE_DAYS=7

# Mother website facility page base URL
# Deals with a CCN will link to {VITE_FACILITY_BASE_URL}/{CCN}
VITE_FACILITY_BASE_URL=https://yourorg.org/facilities
